# Shared
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000
APP_SECRET=replace-with-32-random-bytes-minimum
ADMIN_API_TOKEN=replace-with-admin-setup-token
DATABASE_PATH=./data/ai-journey-dj.db

# API
API_HOST=0.0.0.0
API_PORT=3000
CORS_ORIGIN=http://localhost:5173
SIMULATOR_TOKEN=local-dev-simulator-token
# Background playlist refresh interval (default 12). Use 1 for local testing.
JOURNEY_REFRESH_MINUTES=12

# TIDAL
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=http://localhost:3000/auth/tidal/callback
TIDAL_AUTHORIZATION_URL=https://login.tidal.com/authorize
TIDAL_TOKEN_URL=https://auth.tidal.com/v1/oauth2/token
TIDAL_API_BASE_URL=https://openapi.tidal.com/v2/
TIDAL_COUNTRY_CODE=DE
TIDAL_MOCK=true

# Spotify (set SPOTIFY_MOCK=false and fill credentials for real login)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback
SPOTIFY_AUTHORIZATION_URL=https://accounts.spotify.com/authorize
SPOTIFY_TOKEN_URL=https://accounts.spotify.com/api/token
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
SPOTIFY_MARKET=DE
SPOTIFY_MOCK=true

# Playback reconciliation: detects native (Tesla miniplayer / Spotify Connect) skips and refills.
SPOTIFY_PLAYBACK_POLL_ENABLED=true
SPOTIFY_PLAYBACK_POLL_ACTIVE_SECONDS=5
SPOTIFY_PLAYBACK_POLL_IDLE_SECONDS=30
SPOTIFY_REFILL_THRESHOLD=3
SPOTIFY_REFILL_MIN_INTERVAL_SECONDS=60
PLAYBACK_RESPECT_USER_TAKEOVER=true   # don't push music when you've taken over (podcast / other device)
JOURNEY_INACTIVITY_STOP_MINUTES=45    # auto-stop a journey after N min idle (car off overnight); 0 disables

# Adaptive Drive Mode: bias music toward calm/focus from telemetry (comfort feature, not a safety system).
ADAPTIVE_DRIVE_MODE_ENABLED=true

# Song scout (default: Gemini Flash + Google Search for current hits)
SONG_SCOUT=gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.5-flash

# xAI / Grok (fallback when SONG_SCOUT=xai or no Gemini key)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_MOCK=true

# Open music lookups
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
LISTENBRAINZ_BASE_URL=https://api.listenbrainz.org/1
OPEN_MUSIC_CACHE_TTL_SECONDS=86400

# Last.fm (free API key): geo/tag charts + Momentum Radio (similar-artist graph). Degrades gracefully if empty.
LASTFM_API_KEY=

# Engine v2 — all default on; flip to false to disable a layer.
# NOTE: keep values on their own line. Coolify/direct-env injection does NOT strip inline
# "# comments" (only dotenv files do), so a trailing comment becomes part of the value.
# DRIVE_STORY_ENABLED: narrative arc (opening → climax → finale) + opening-title anchor
DRIVE_STORY_ENABLED=true
# MOMENTS_ENABLED: situational re-curation (jam release, border crossing, golden hour, arrival …)
MOMENTS_ENABLED=true
# SIMILAR_SOURCE_ENABLED: Momentum Radio over the Last.fm similar graph
SIMILAR_SOURCE_ENABLED=true
# Engine-Frische: echter Release-Radar + datum-basiertes Recency + Frische-Quote
# SPOTIFY_FRESH_ENABLED: pull real new releases from Taste-Artist albums + curated New Releases
SPOTIFY_FRESH_ENABLED=true
# FRESH_WINDOW_DAYS: how far back (days) counts as "fresh" (default 75)
FRESH_WINDOW_DAYS=75
# FRESH_CACHE_HOURS: cache TTL for fresh-track lookups (default 24)
FRESH_CACHE_HOURS=24
# FRESH_QUOTA_MIN: minimum fresh slots per refill (default 2; 0 disables quota)
FRESH_QUOTA_MIN=2
# FRESH_CHART_WINDOW: Last.fm chart pool size when fresh mode is on (default 40, tighter = fresher chart)
FRESH_CHART_WINDOW=40
# RECENCY_DATE_SCORING_ENABLED: boost tracks by release date in the scoring curve
RECENCY_DATE_SCORING_ENABLED=true
# CURRENCY_LENS_GROUNDING_ENABLED: ground the 'current' lens with real Spotify release facts so the LLM stops guessing currency
CURRENCY_LENS_GROUNDING_ENABLED=true
# EXPLORER_LENS_ENABLED: deep-cut explorer lens (B-sides, lesser-known)
EXPLORER_LENS_ENABLED=true
# GENRE_SPREAD_ENABLED: no two same-mood tracks back-to-back
GENRE_SPREAD_ENABLED=true
# SKIP_FEEDBACK_ENABLED: learn the session mood from skips
SKIP_FEEDBACK_ENABLED=true
# WHY_LINE_ENABLED: server-composed "Why this song?" line
WHY_LINE_ENABLED=true
# SPOKEN_WORD_FILTER_ENABLED: hard-exclude Hörspiele / audiobooks / spoken-word from the queue
SPOKEN_WORD_FILTER_ENABLED=true
# ARTIST_BAN_PLAYS: ban an artist after N recent plays (cross-journey variety)
ARTIST_BAN_PLAYS=2
# LYRICS_ENABLED: synced karaoke/singalong lyrics in the cockpit (via LRCLIB)
LYRICS_ENABLED=true
# LRCLIB_BASE_URL: lyrics source (free, no API key). Leave default unless self-hosting LRCLIB.
LRCLIB_BASE_URL=https://lrclib.net

# Tesla Fleet Telemetry streaming (set TESLA_TELEMETRY_ENABLED=true; see docs/deployment.md)
TESLA_TELEMETRY_ENABLED=false
MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=tesla/telemetry
STREAM_FRESH_WINDOW_SECONDS=90
TESLA_TELEMETRY_HOST=telemetry.aijourneydj.ruhrco.de
TESLA_TELEMETRY_PORT=4443
TESLA_TELEMETRY_CA_PEM=
TESLA_TELEMETRY_VINS=
TESLA_COMMAND_PROXY_URL=https://vehicle-command:4444
# The vehicle-command proxy serves an internal/self-signed TLS cert. Node reads NODE_EXTRA_CA_CERTS at
# process start; set it in Coolify (+ mount that cert) so the API's fetch trusts the proxy. This is the
# actual trust mechanism — there is no app-level CA-path config.
NODE_EXTRA_CA_CERTS=/config/vehicle-command/tls-cert.pem
TESLA_VEHICLE_PUBLIC_KEY_PATH=./docker/tesla/public_key.pem
TESLA_FLEET_SERVER_IMAGE=tesla/fleet-telemetry:latest

# Tesla Fleet API (read-only polling — set TESLA_FLEET_ENABLED=true in production, EU region)
TESLA_FLEET_ENABLED=false
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_OAUTH_AUTH_URL=https://auth.tesla.com/oauth2/v3/authorize
TESLA_OAUTH_TOKEN_URL=https://auth.tesla.com/oauth2/v3/token
TESLA_API_BASE_URL=https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_REDIRECT_URI=http://localhost:3000/auth/tesla/callback
# Paste the PUBLIC EC (prime256v1) PEM; served at /.well-known/appspecific/com.tesla.3p.public-key.pem
TESLA_PUBLIC_KEY_PEM=
# Poll cadence in seconds. Each tick = one billed vehicle_data request; 120s keeps cost low.
TESLA_POLL_SECONDS=120
# Optional: pin a specific vehicle (else discovered once and cached — avoids repeat list calls).
# TESLA_VEHICLE_ID=
GEOCODER_URL=https://nominatim.openstreetmap.org/reverse
GEOCODER_SEARCH_URL=https://nominatim.openstreetmap.org/search  # forward geocode (destination → region) for the no-GPS geo fallback
