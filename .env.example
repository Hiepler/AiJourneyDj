# Shared
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000
APP_SECRET=replace-with-32-random-bytes-minimum
ADMIN_API_TOKEN=replace-with-admin-setup-token
DATABASE_PATH=./data/ai-journey-dj.db

# API
API_HOST=0.0.0.0
API_PORT=3000
CORS_ORIGIN=http://localhost:5173
SIMULATOR_TOKEN=local-dev-simulator-token
# Background playlist refresh interval (default 12). Use 1 for local testing.
JOURNEY_REFRESH_MINUTES=12

# TIDAL
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=http://localhost:3000/auth/tidal/callback
TIDAL_AUTHORIZATION_URL=https://login.tidal.com/authorize
TIDAL_TOKEN_URL=https://auth.tidal.com/v1/oauth2/token
TIDAL_API_BASE_URL=https://openapi.tidal.com/v2/
TIDAL_COUNTRY_CODE=DE
TIDAL_MOCK=true

# Spotify (set SPOTIFY_MOCK=false and fill credentials for real login)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback
SPOTIFY_AUTHORIZATION_URL=https://accounts.spotify.com/authorize
SPOTIFY_TOKEN_URL=https://accounts.spotify.com/api/token
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
SPOTIFY_MARKET=DE
SPOTIFY_MOCK=true

# Playback reconciliation: detects native (Tesla miniplayer / Spotify Connect) skips and refills.
SPOTIFY_PLAYBACK_POLL_ENABLED=true
SPOTIFY_PLAYBACK_POLL_ACTIVE_SECONDS=5
SPOTIFY_PLAYBACK_POLL_IDLE_SECONDS=30
SPOTIFY_REFILL_THRESHOLD=3
SPOTIFY_REFILL_MIN_INTERVAL_SECONDS=60

# Adaptive Drive Mode: bias music toward calm/focus from telemetry (comfort feature, not a safety system).
ADAPTIVE_DRIVE_MODE_ENABLED=true

# Song scout (default: Gemini Flash + Google Search for current hits)
SONG_SCOUT=gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.5-flash

# xAI / Grok (fallback when SONG_SCOUT=xai or no Gemini key)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_MOCK=true

# Open music lookups
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
LISTENBRAINZ_BASE_URL=https://api.listenbrainz.org/1
OPEN_MUSIC_CACHE_TTL_SECONDS=86400

# Tesla Fleet Telemetry streaming (set TESLA_TELEMETRY_ENABLED=true; see docs/deployment.md)
TESLA_TELEMETRY_ENABLED=false
MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=tesla/telemetry
STREAM_FRESH_WINDOW_SECONDS=90
TESLA_TELEMETRY_HOST=telemetry.aijourneydj.ruhrco.de
TESLA_TELEMETRY_PORT=4443
TESLA_TELEMETRY_CA_PEM=
TESLA_TELEMETRY_VINS=
TESLA_COMMAND_PROXY_URL=https://vehicle-command:4444
# The vehicle-command proxy serves an internal/self-signed TLS cert. Node reads NODE_EXTRA_CA_CERTS at
# process start; set it in Coolify (+ mount that cert) so the API's fetch trusts the proxy. This is the
# actual trust mechanism — there is no app-level CA-path config.
NODE_EXTRA_CA_CERTS=/config/vehicle-command/tls-cert.pem
TESLA_VEHICLE_PUBLIC_KEY_PATH=./docker/tesla/public_key.pem
TESLA_FLEET_SERVER_IMAGE=tesla/fleet-telemetry:latest

# Tesla Fleet API (read-only polling — set TESLA_FLEET_ENABLED=true in production, EU region)
TESLA_FLEET_ENABLED=false
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_OAUTH_AUTH_URL=https://auth.tesla.com/oauth2/v3/authorize
TESLA_OAUTH_TOKEN_URL=https://auth.tesla.com/oauth2/v3/token
TESLA_API_BASE_URL=https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_REDIRECT_URI=http://localhost:3000/auth/tesla/callback
# Paste the PUBLIC EC (prime256v1) PEM; served at /.well-known/appspecific/com.tesla.3p.public-key.pem
TESLA_PUBLIC_KEY_PEM=
# Poll cadence in seconds. Each tick = one billed vehicle_data request; 120s keeps cost low.
TESLA_POLL_SECONDS=120
# Optional: pin a specific vehicle (else discovered once and cached — avoids repeat list calls).
# TESLA_VEHICLE_ID=
GEOCODER_URL=https://nominatim.openstreetmap.org/reverse
